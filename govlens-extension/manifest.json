{
  "manifest_version": 3,
  "name": "GovLens – Universal Government Portal Reader",
  "version": "2.1.2",
  "description": "Read any government portal in your language. Translation, page map, cross-language search. Works in 25+ countries.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.gov.in/*",
    "https://*.nic.in/*",
    "https://*.gov.uk/*",
    "https://*.gov/*",
    "https://*.mil/*",
    "https://*.gc.ca/*",
    "https://*.canada.ca/*",
    "https://*.gov.au/*",
    "https://*.govt.nz/*",
    "https://*.europa.eu/*",
    "https://*.gouv.fr/*",
    "https://*.bund.de/*",
    "https://*.gob.es/*",
    "https://*.gob.mx/*",
    "https://*.gob.cl/*",
    "https://*.gob.pe/*",
    "https://*.gob.ar/*",
    "https://*.gov.br/*",
    "https://*.gov.it/*",
    "https://*.go.jp/*",
    "https://*.lg.jp/*",
    "https://*.gov.cn/*",
    "https://*.gov.sg/*",
    "https://*.gov.za/*",
    "https://*.gov.pk/*",
    "https://*.gov.bd/*",
    "https://*.gov.lk/*",
    "https://*.gov.np/*",
    "https://*.gov.ie/*",
    "https://translate.googleapis.com/*",
    "https://api.anthropic.com/*"
  ],
  "action": {
    "default_title": "Open GovLens",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.gov.in/*",
        "https://*.nic.in/*",
        "https://*.gov.uk/*",
        "https://*.gov/*",
        "https://*.mil/*",
        "https://*.gc.ca/*",
        "https://*.canada.ca/*",
        "https://*.gov.au/*",
        "https://*.govt.nz/*",
        "https://*.europa.eu/*",
        "https://*.gouv.fr/*",
        "https://*.bund.de/*",
        "https://*.gob.es/*",
        "https://*.gob.mx/*",
        "https://*.gob.cl/*",
        "https://*.gob.pe/*",
        "https://*.gob.ar/*",
        "https://*.gov.br/*",
        "https://*.gov.it/*",
        "https://*.go.jp/*",
        "https://*.lg.jp/*",
        "https://*.gov.cn/*",
        "https://*.gov.sg/*",
        "https://*.gov.za/*",
        "https://*.gov.pk/*",
        "https://*.gov.bd/*",
        "https://*.gov.lk/*",
        "https://*.gov.np/*",
        "https://*.gov.ie/*"
      ],
      "js": ["regions.js", "jargon.js", "content.js"],
      "css": ["overlay.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
